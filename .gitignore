# Build output, caches, and shippable apps — distributed via GitHub Releases, not committed.
.DS_Store
*.dSYM/

# macOS (SwiftUI) build
**/.build/
**/*.app/

# Icon build intermediate (regenerated by icon/make.sh; committed deliverables are
# AppIcon.icns, app.ico, icon_1024.png + the generator scripts).
**/AppIcon.iconset/

# Local reference art (not published)
/JBTheatreTools/icon/og logo.png

# Windows (.NET / WinForms) build
**/bin/
**/obj/
**/dist/

# Launcher runtime: downloaded app payloads / caches (other apps' release assets — never commit)
/downloads/
/cache/

# Secrets — the auth token, never committed.
*.token
.env

# Local-only docs (not published)
/CLAUDE.md
/docs/dev-kickoff.md
